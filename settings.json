{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "allow": [
      "mcp__plugin_playwright_playwright__*"
    ]
  },
  "model": "opus[1m]",
  "statusLine": {
    "type": "command",
    "command": "bash /home/ubuntu/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "claude-mem@thedotmack": true,
    "frontend-design@claude-plugins-official": false,
    "code-simplifier@claude-plugins-official": true,
    "superpowers@claude-plugins-official": false,
    "playwright@claude-plugins-official": true,
    "cli-anything@cli-anything": true,
    "everything-claude-code@everything-claude-code": true,
    "ui-ux-pro-max@ui-ux-pro-max-skill": true,
    "autoresearch@autoresearch": true,
    "codex@openai-codex": true
  },
  "extraKnownMarketplaces": {
    "cli-anything": {
      "source": {
        "source": "github",
        "repo": "HKUDS/CLI-Anything"
      }
    },
    "everything-claude-code": {
      "source": {
        "source": "github",
        "repo": "affaan-m/everything-claude-code"
      }
    },
    "ui-ux-pro-max-skill": {
      "source": {
        "source": "github",
        "repo": "nextlevelbuilder/ui-ux-pro-max-skill"
      }
    },
    "autoresearch": {
      "source": {
        "source": "github",
        "repo": "uditgoenka/autoresearch"
      }
    },
    "openai-codex": {
      "source": {
        "source": "github",
        "repo": "openai/codex-plugin-cc"
      }
    }
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "if echo \"$CLAUDE_TOOL_INPUT\" | grep -q 'claude plugin install\\|claude plugin marketplace add\\|claude plugin uninstall\\|claude plugin remove'; then bash ~/.claude/scripts/sync-plugins.sh; fi"
          }
        ]
      }
    ]
  },
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "filesystem": {
      "allowWrite": [
        "/tmp/",
        "~/.claude/",
        "~/project/"
      ],
      "denyRead": []
    },
    "excludedCommands": [],
    "permissions": {
      "allow": [
        "Bash(npm *)",
        "Bash(git *)",
        "Bash(* --version)",
        "Bash(* --help *)",
        "WebSearch",
        "WebFetch(domain:github.com)",
        "WebFetch(domain:claude.com)",
        "mcp__plugin_claude-mem_mcp-*",
        "mcp__plugin_playwright_playwright__*",
        "mcp__serena__*"
      ],
      "deny": [
        "Bash(rm *)"
      ]
    }
  },
  "network": {
    "allowedDomains": [
      "github.com",
      "*.npmjs.org",
      "registry.yarnpkg.com",
      "api.openai.com"
    ],
    "allowUnixSockets": [
      "/var/run/docker.sock"
    ],
    "allowLocalBinding": true
  }
}
